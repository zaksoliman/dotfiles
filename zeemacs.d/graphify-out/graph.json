    {
      "label": "gc-cons-threshold Memory Leak",
      "file_type": "rationale",
      "source_file": "refactoring_plan.md",
      "source_location": "line 8",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "early-init.el sets gc-cons-threshold to most-positive-fixnum for startup speed but never resets it, causing unlimited RAM usage and potential freezes. Fix: add a hook to reset to ~16MB after startup.",
      "id": "zeemacs_d_refactoring_plan_gc_memory_leak",
      "community": 1,
      "norm_label": "gc-cons-threshold memory leak"
    },
    {
      "label": "Hardcoded Paths Issue",
      "file_type": "rationale",
      "source_file": "refactoring_plan.md",
      "source_location": "line 9",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Functions in core/functions.el and core/base.el use hardcoded paths (e.g. ~/dotfiles/zeemacs.d), breaking portability. Fix: replace with user-emacs-directory and expand-file-name.",
      "id": "zeemacs_d_refactoring_plan_hardcoded_paths",
      "community": 1,
      "norm_label": "hardcoded paths issue"
    },
    {
      "label": "Variable Inconsistency Issue",
      "file_type": "rationale",
      "source_file": "refactoring_plan.md",
      "source_location": "line 12",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Variables defined in core/variables.el (e.g. zeds/org-path) are not actually used in init.el, where paths remain hardcoded. Should standardize usage.",
      "id": "zeemacs_d_refactoring_plan_variable_inconsistency",
      "community": 4,
      "norm_label": "variable inconsistency issue"
    },
    {
      "label": "Skeleton & Injection Keymap Pattern",
      "file_type": "rationale",
      "source_file": "refactoring_plan.md",
      "source_location": "line 20",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Modernizes keybinding setup using native Emacs 29+ defvar-keymap: define empty skeleton keymaps in a core file (establishing menu structure without loading plugins), then inject bindings via use-package :bind within each package configuration. Ensures keys only bound if package present and keeps config co-located.",
      "id": "zeemacs_d_refactoring_plan_skeleton_injection",
      "community": 5,
      "norm_label": "skeleton & injection keymap pattern"
